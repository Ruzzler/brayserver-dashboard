<?xml version="1.0"?>
<Container version="2">
  <Name>BrayDashy-Dashboard</Name>
  <Repository>ghcr.io/ruzzler/braydashy-dashboard:latest</Repository>
  <Registry>https://github.com/Ruzzler/braydashy-dashboard/pkgs/container/braydashy-dashboard</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/Ruzzler/braydashy-dashboard/issues</Support>
  <Project>https://github.com/Ruzzler/braydashy-dashboard</Project>
  <Overview>
    A custom, beautiful, and highly dynamic unraid landing page dashboard for your server apps. Features a real-time reactive UI, 4 interchangeable layout styles, and live infrastructure metrics.
  </Overview>
  <Category>Tools: Network:Web</Category>
  <WebUI>http://[IP]:[PORT:3050]/</WebUI>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/Ruzzler/braydashy-dashboard/main/icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled></DateInstalled>
  <DonateText/>
  <DonateLink/>
  <Requires/>
  <Config Name="WebUI Port" Target="3050" Default="3050" Mode="tcp" Description="The port the dashboard is accessible on" Type="Port" Display="always" Required="true" Mask="false">3050</Config>
  <Config Name="App Data Directory" Target="/app/data" Default="/mnt/user/appdata/braydashy/" Mode="rw" Description="Persistent storage folder for your dashboard configuration file." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/braydashy/</Config>
</Container>
